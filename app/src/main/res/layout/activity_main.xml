<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0A0E14">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YAC BRIDGE VPN"
        android:textColor="#00D4FF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚪ Отключено"
        android:textColor="#E8F4FD"
        android:textSize="18sp"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gateway URL"
        android:textColor="#6B8BA4"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etGateway"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#E8F4FD"
        android:textColorHint="#6B8BA4"
        android:hint="wss://..."
        android:background="#111820"
        android:padding="12dp"
        android:textSize="12sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Auth Token"
        android:textColor="#6B8BA4"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etToken"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#E8F4FD"
        android:textColorHint="#6B8BA4"
        android:hint="токен"
        android:background="#111820"
        android:padding="12dp"
        android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="ПОДКЛЮЧИТЬ"
        android:textColor="#0A0E14"
        android:textStyle="bold"
        android:backgroundTint="#00D4FF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnDisconnect"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="ОТКЛЮЧИТЬ"
        android:textColor="#0A0E14"
        android:textStyle="bold"
        android:backgroundTint="#FF4444"
        android:enabled="false"/>

</LinearLayout>
